{
  "name": "cmcc",
  "version": "1.0.0",
  "description": "Content Moderation Command Center - Monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "platforms/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:eslint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "turbo": "^1.10.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.60.1"
  }
}
