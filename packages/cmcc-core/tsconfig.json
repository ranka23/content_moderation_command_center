{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2022"],
    "allowJs": false,
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
}
