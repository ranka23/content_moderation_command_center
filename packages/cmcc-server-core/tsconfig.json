{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    /* CommonJS for Node.js backends (Strapi, Express, Shopify) */
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"],
}
