{
  "name": "@cmcc/wix",
  "version": "1.0.0",
  "description": "CMCC Content Moderation App for Wix",
  "main": "dist/app.js",
  "keywords": [
    "wix",
    "app",
    "content-moderation",
    "cmcc"
  ],
  "scripts": {
    "build": "test -d src && webpack --mode production || echo 'No src directory yet, skipping build'",
    "start": "node server/index.js",
    "dev": "webpack --mode development --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:server": "node --experimental-vm-modules node_modules/.bin/jest --config jest.server.config.js",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.24.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.0",
    "css-loader": "^6.0.0",
    "mini-css-extract-plugin": "^2.0.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.4.11",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "@cmcc/core": "^1.0.0",
    "@cmcc/server-core": "^1.0.0",
    "@cmcc/ui": "^1.0.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  }
}
